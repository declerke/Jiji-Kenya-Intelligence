# Jiji Kenya Intelligence — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# Airflow
AIRFLOW__WEBSERVER__SECRET_KEY=change-me-in-production

# DuckDB path (local dev override)
DUCKDB_PATH=./data/jiji.duckdb

# Staging directory (local dev override)
STAGING_DIR=./staging
